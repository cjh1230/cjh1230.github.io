---
import { hero, author } from '@/config.json'
import SocialList from './SocialList.astro'
---

<div class="lg:-mt-16 lg:h-dvh lg:min-h-[720px]">
  <div
    class="relative max-w-[1300px] mx-auto h-full px-4 grid lg:grid-cols-2 items-center justify-items-center"
  >
    <div class="mt-[120px] lg:mt-0 max-w-[590px]">
      <h1 class="text-5xl font-bold text-center lg:text-left char-bounce">
        <span>c</span><span>i</span><span>n</span>
      </h1>
      <p class="text-xl text-center lg:text-left text-secondary mt-4 animate-fade-slide-up" style="--delay: 800ms">
        让机器看见世界。
      </p>
      <p class="text-sm text-center lg:text-left text-secondary/60 mt-3 animate-fade-slide-up" style="--delay: 1000ms">
        嵌入式 / CV / 机器人
      </p>

      <SocialList className="mt-10" />
    </div>

    <div class="mt-20 lg:mt-0 relative">
      <div class="relative size-[200px] lg:size-[300px] group">
        <div
          class="size-full rounded-full overflow-hidden border-2 border-primary/50 bg-gradient-to-br from-white/10 to-black/10 dark:from-zinc-800 dark:to-zinc-900 animate-popup-spring avatar-clickable"
        >
          <img
            class="size-full object-cover transition-transform duration-700 group-hover:scale-105"
            src={author.avatar}
            alt={`${hero.name} 的头像`}
            width="300"
            height="300"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <div class="mt-10 lg:mt-0 lg:absolute inset-x-0 bottom-0 flex flex-col items-center">
      <div class="mt-8 flex flex-col items-center space-y-4">
        <div class="text-lg animate-bounce" style="animation-duration: 2s;">
          <i class="iconfont icon-down"></i>
        </div>
        <div class="text-xs text-secondary animate-pulse">向下滚动</div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes gentle-pulse {
    0%,
    100% { opacity: 0.6; }
    50% { opacity: 1; }
  }
  .animate-pulse {
    animation: gentle-pulse 3s ease-in-out infinite;
  }

  .char-bounce span {
    display: inline-block;
    opacity: 0;
    animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  .char-bounce span:nth-child(1) { animation-delay: 0.3s; }
  .char-bounce span:nth-child(2) { animation-delay: 0.45s; }
  .char-bounce span:nth-child(3) { animation-delay: 0.6s; }
  @keyframes pop-in {
    from {
      opacity: 0;
      transform: translateY(0.6em) scale(0.5);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
