---
import { hero } from '@/config.json'

interface Props {
  className?: string
}

const { className = '' } = Astro.props
---

<ul class={`flex gap-4 flex-wrap items-center justify-center lg:justify-start ${className}`}>
  {hero.socials.map((social, i) => (
    <li style={`--delay: ${i * 100}ms`} class="animate-bounce-in opacity-0">
      <a
        class="relative size-9 text-white text-xl flex justify-center items-center group"
        href={social.url}
        title={social.name}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span
          class="absolute inset-0 -z-1 rounded-full group-hover:scale-105 transition animate-float-subtle"
          style={`background-color: ${social.color}; --delay: ${i * 400}ms`}
        ></span>
        <i class={`iconfont ${social.icon}`} />
      </a>
    </li>
  ))}
</ul>
